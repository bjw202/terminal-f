{
  "name": "ai-pair-dev",
  "params": [
    {
      "name": "repo",
      "prompt": "Which repo folder?",
      "kind": "folder"
    }
  ],
  "root": {
    "kind": "split",
    "direction": "row",
    "ratio": 0.5,
    "first": {
      "kind": "split",
      "direction": "col",
      "ratio": 0.6,
      "first": {
        "kind": "pane",
        "cwd": "${repo}",
        "labels": ["claude"],
        "startupCommand": "claude"
      },
      "second": {
        "kind": "pane",
        "cwd": "${repo}",
        "labels": ["shell"]
      }
    },
    "second": {
      "kind": "pane",
      "cwd": "${repo}",
      "labels": ["codex"],
      "allowInjection": true,
      "allowObserve": true,
      "startupCommand": "git status"
    }
  }
}
