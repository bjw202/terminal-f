{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "terminal-f",
  "version": "0.1.1",
  "identifier": "com.terminalf.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "terminal-f",
        "width": 1280,
        "height": 800,
        "minWidth": 640,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/32x32.png", "icons/128x128.png"]
  }
}
